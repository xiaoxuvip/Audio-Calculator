<Window x:Class="AudioCalculator.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙️ 设置" FontSize="18" FontWeight="Bold" 
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📋 右键菜单" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="添加到 Windows 右键菜单，支持多选文件" 
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="添加" Style="{StaticResource PrimaryButton}" Padding="14,8"
                                    Click="AddContextMenu_Click" FontSize="12"/>
                            <Button Content="移除" Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="8,0,0,0"
                                    Click="RemoveContextMenu_Click" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ℹ️ 关于" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="音频时长统计与结算工具" FontSize="12" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="快速统计音频文件时长，计算费用，一键截图分享" 
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="版本："/>
                            <Run x:Name="VersionText" Text="0.1"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                            <Run Text="开发者：Xiaoxu"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="关闭" Style="{StaticResource SecondaryButton}" Padding="20,8"
                Click="Close_Click" FontSize="12" HorizontalAlignment="Right" Margin="0,16,0,0"/>
    </Grid>
</Window>
