<!-- 打赏支持窗口
     显示感谢文字、微信收款码和获取最新版链接 -->
<Window x:Class="AudioCalculator.DonateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打赏支持"
        Width="420" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        Icon="logo.ico">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- 标题区 -->
            <RowDefinition Height="Auto"/>
            <!-- 内容区 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <Border Grid.Row="0" Padding="0,28,0,20">
            <TextBlock Text="💖 感谢您的支持" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#EC4899"/>
        </Border>

        <!-- 内容区 -->
        <StackPanel Grid.Row="1" Margin="32,0,32,24">
            <!-- 感谢文字卡片 -->
            <Border Background="#EEF2FF" CornerRadius="12" Padding="20,16" Margin="0,0,0,20">
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="13" LineHeight="22" Foreground="#475569">
                    <Run Text="本软件完全免费，由作者"/>
                    <Run Text=" Xiaoxu " FontWeight="Bold" Foreground="#6366F1"/>
                    <Run Text="独立开发维护。"/>
                    <LineBreak/>
                    <Run Text="如果觉得好用，欢迎打赏一杯咖啡 ☕"/>
                    <LineBreak/>
                    <Run Text="您的支持是我持续更新的最大动力！"/>
                </TextBlock>
            </Border>

            <!-- 微信收款码标题 -->
            <TextBlock Text="微信收款码" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#6366F1"
                       Margin="0,0,0,12"/>

            <!-- 二维码图片 -->
            <Border Background="White" CornerRadius="12" Padding="16"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="#000"/>
                </Border.Effect>
                <Image Source="sk.jpg" Width="240" Height="240"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- 底部获取最新版链接 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock Text="获取最新版本：" FontSize="12" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
                <TextBlock FontSize="12" VerticalAlignment="Center" Cursor="Hand"
                           MouseLeftButtonDown="Website_Click">
                    <Hyperlink NavigateUri="https://www.xiaoxu.vip" RequestNavigate="Hyperlink_Navigate">
                        <Run Text="www.xiaoxu.vip" Foreground="#6366F1" FontWeight="SemiBold"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
