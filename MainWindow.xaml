<Window x:Class="AudioCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="音频时长统计与结算" 
        Height="620" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanMinimize"
        Icon="logo.ico">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 - 与背景融合 -->
        <Border Grid.Row="0" Padding="20,16,20,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo图标 - 可点击 -->
                    <Button Click="OpenWebsite_Click" Cursor="Hand" ToolTip="点击获取最新版">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="logoBorder" Background="#FFFFFF30" CornerRadius="10" Width="42" Height="42" Margin="0,0,12,0">
                                    <TextBlock Text="🎵" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="logoBorder" Property="Background" Value="#FFFFFF50"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="音频时长统计" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="👈点击图标获取最新版" FontSize="10" Foreground="#FFFFFFAA" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <!-- 右键菜单按钮 - 现代商务风格 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="添加右键" FontSize="11" FontWeight="Medium" ToolTip="添加到右键菜单" Click="AddContextMenu_Click"
                            Margin="0,0,4,0" Foreground="#1E40AF">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="6" Padding="8,6"
                                        Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#BFDBFE"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#60A5FA"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#93C5FD"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="移除右键" FontSize="11" FontWeight="Medium" ToolTip="从右键菜单移除" Click="RemoveContextMenu_Click"
                            Foreground="#9F1239">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="6" Padding="8,6"
                                        Background="#FFE4E6" BorderBrush="#FDA4AF" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FECDD3"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FB7185"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FDA4AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 打赏按钮 -->
                    <Button Content="☕打赏" FontSize="11" FontWeight="Medium" ToolTip="打赏支持作者" Click="Donate_Click"
                            Foreground="#92400E" Margin="4,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="6" Padding="8,6"
                                        Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FDE68A"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FBBF24"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FCD34D"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="16,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 文件列表区域 -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}" CornerRadius="12" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="#000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="16,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="文件列表" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="FileCountText" Text="(0 个)" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="清空" HorizontalAlignment="Right" Click="ClearFiles_Click"
                                    Style="{StaticResource SecondaryButton}" Padding="10,4" FontSize="11"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="FileListView" Grid.Row="1" BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="6,0,6,6"
                              AllowDrop="True" Drop="FileListView_Drop" DragOver="FileListView_DragOver">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FAFAFA" CornerRadius="6" Margin="2,2" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FileName}" FontSize="12" 
                                                   Foreground="{StaticResource TextBrush}" 
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="#EEF2FF" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding DurationText}" FontSize="11" 
                                                       Foreground="{StaticResource PrimaryBrush}" FontWeight="Medium"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <Border Background="#F0F9FF" CornerRadius="40" Width="64" Height="64" HorizontalAlignment="Center">
                            <TextBlock Text="📂" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="拖拽音频文件到此处" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextBrush}" 
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="或点击下方按钮选择" FontSize="11" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 统计区域 - 单行显示 -->
            <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="12" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,12,0,0" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="#000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⏱️" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalDurationText" Text="00:00:00" FontSize="20" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalPriceText" Text="¥0.00" FontSize="20" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 计费设置区域 -->
            <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,10,0,0" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="#000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="单价:" FontSize="12" Foreground="{StaticResource TextBrush}" 
                               VerticalAlignment="Center" FontWeight="Medium"/>
                    
                    <TextBox x:Name="PriceInput" Text="100" FontSize="13" Width="60"
                             Margin="10,0,6,0" Padding="8,6" VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                             TextAlignment="Center" TextChanged="PriceInput_TextChanged">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="元/" FontSize="12" Foreground="{StaticResource TextBrush}" 
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    
                    <RadioButton x:Name="RadioHour" Content="小时" IsChecked="True" 
                                 Style="{StaticResource ModernRadioButton}" 
                                 Checked="Unit_Changed" Margin="0,0,20,0"/>
                    <RadioButton x:Name="RadioMinute" Content="分钟" 
                                 Style="{StaticResource ModernRadioButton}"
                                 Checked="Unit_Changed"/>
                </StackPanel>
            </Border>

            <!-- 操作按钮区域 -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="📂 文件" Style="{StaticResource SecondaryButton}" 
                        Click="SelectFiles_Click" Margin="0,0,4,0" Padding="12,10" FontSize="12"/>
                <Button Grid.Column="1" Content="📁 文件夹" Style="{StaticResource SecondaryButton}" 
                        Click="SelectFolder_Click" Margin="4,0" Padding="12,10" FontSize="12"/>
                <Button Grid.Column="2" Content="📷 截图" Style="{StaticResource PrimaryButton}" 
                        Click="CopyScreenshot_Click" Margin="4,0,0,0" Padding="12,10" FontSize="12"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
